---
import type { Series } from "@data/home";

import { Image } from "astro:assets";
import curryBg from "@assets/curry-bg.png";
import kariiChan from "@assets/staff-pfps/karii-chan.png";
import SeriesGrid from "@components/novels/SeriesGrid.astro";

const { series } = Astro.props as { series: Series[] }
---

<section class="hero flex flex-col relative">
  <div class="hero-bg w-full overflow-hidden absolute" aria-hidden="true">
    <Image src={curryBg} class="w-full h-full object-cover scale-[1.05]" alt="" />
    <div class="absolute inset-0 bg-bg/70"/>
    <div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(21,24,29,0)_0%,var(--color-bg)_70%)]"/>
  </div>

  <div class="z-0">

	<header class="flex min-h-[60vh] flex-col items-center justify-center gap-6 p-6 text-center sm:min-h-[60vh] md:flex-row md:gap-[40px] md:p-[40px]">
		<div class="hero-title flex max-w-xl flex-col text-center md:max-w-2/3 md:text-right">
			<p class="hero-accent bg-gradient-to-b from-[#F07A26] to-[#a85b23] bg-clip-text text-6xl font-serif italic leading-none text-transparent sm:text-6xl md:text-[140px]">Curry Muncher</p>
			<p class="hero-main text-5xl font-sans sm:text-5xl md:text-[110px]">Translations</p>
			<p class="hero-tagline mt-4 text-lg italic text-white/80 sm:text-base">- bringing curry to your doorstep since 2024</p>
		</div>
		<div class="hero-avatar h-44 w-44 overflow-hidden rounded-full bg-[#DB762E] sm:h-44 sm:w-44 md:h-[20vw] md:w-[20vw]">
			<div class="avatar-ring"></div>
			<Image src={kariiChan} alt="Karii-chan" class="relative top-[22px] rotate-[8deg] scale-[0.9]" />
		</div>
	</header>

	<SeriesGrid series={series} layout="hero" showPlaceholder />
  </div>
</section>