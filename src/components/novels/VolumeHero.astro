---
import { Image } from 'astro:assets';
import { Icon } from 'astro-icon/components';

interface Props {
	backgroundImage?: string;
	status: string;
	volumeCount: number;
	volumeNumber: number;
	volumeTitle: string;
	novelSlug: string;
	novelTitle: string;
}

const { backgroundImage, status, volumeCount, volumeNumber, volumeTitle, novelSlug, novelTitle } = Astro.props as Props;
---

<nav aria-label="Breadcrumb" class="min-w-0">
	<ol class="flex flex-wrap items-center justify-start gap-1 text-[12px] text-white/50 sm:text-[13px]">
		<li><a href="/novels" class="transition hover:text-white">Series</a></li>
		<li class="text-white/55">/</li>
		<li><a href={`/novels/${novelSlug}`} class="transition hover:text-white">{novelTitle}</a></li>
		<li class="text-white/55">/</li>
		<li class="truncate text-white">{volumeTitle}</li>
	</ol>
</nav>
<section class="relative overflow-hidden rounded-[15px] shadow-[0_18px_60px_rgba(0,0,0,0.35)]">
	<div class="absolute inset-0 overflow-hidden rounded-[15px]" aria-hidden="true">
		{backgroundImage ? <Image inferSize={true} src={backgroundImage} alt="" class="h-full w-full object-cover object-[center_20%]" /> : null}
	</div>
	<div class="absolute inset-0 bg-[#A3C8FF]/20"></div>
	<div class="absolute inset-0 bg-[linear-gradient(90deg,#2E5566_0%,rgba(46,85,102,0.40)_42%,rgba(46,85,102,0)_100%)]"></div>

	<div class="relative flex h-[224px] flex-col justify-between px-4 pb-4 pt-3 sm:h-[244px] sm:px-6 sm:pb-5 sm:pt-4">
		<div class="flex items-start justify-between gap-3">
			<a href={`/novels/${novelSlug}`} class="inline-flex h-8 items-center gap-1.5 rounded-[10px] bg-white/18 px-3 text-[13px] font-medium text-white transition hover:bg-white/28">
				<Icon name="lucide:arrow-left" class="size-4" />
				<span>Back</span>
			</a>
		</div>

		<div>
			<div class="flex flex-wrap items-center gap-2 text-[10px] sm:text-xs">
				<span class="rounded-full bg-white/20 px-2 py-0.5 font-light lowercase tracking-wide text-white">{status}</span>
				<span class="text-white/85">• {volumeCount} Volume(s)</span>
			</div>

			<h1 class="max-w-[760px] text-[30px] font-semibold uppercase leading-[1.1] tracking-[0.02em] text-white sm:text-[40px]">
				{volumeTitle}
			</h1>
		</div>
	</div>
</section>