---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/home/Hero.astro";
import LatestChapters from "@components/home/LatestChapters.astro";
import StaffSection from "@components/home/StaffSection.astro";
import AffiliatesSection from "@components/home/AffiliatesSection.astro";
import InfoSplit from "@components/home/InfoSplit.astro";

import { series, affiliates, chapters, staff } from "@data/home";
---

<BaseLayout title="Curry Muncher Translations">
	<Hero series={series}/>

	<div class="z-150 mx-4 mt-12 mb-12 flex flex-col gap-14 sm:mx-6 md:mx-12 lg:mx-48">
		<LatestChapters chapters={chapters} />
		<AffiliatesSection affiliates={affiliates} />
		<StaffSection staff={staff} />
		<InfoSplit />
	</div>

</BaseLayout>