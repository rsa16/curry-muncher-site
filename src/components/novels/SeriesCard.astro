---
import { Image } from "astro:assets";
import type { Series } from "@data/home";

interface Props extends Series {
	class?: string;
}

const { cover, alt, title, href, class: className = "" } = Astro.props as Props;
const isRemoteCover = typeof cover === "string";
---

<a
	href={href}
	class:list={[
	"group relative block overflow-hidden rounded-[20px] bg-[#221818] shadow-[0_20px_40px_rgba(0,0,0,0.32)]",
	className,
	]}
>
	<Image
		src={cover as ImageMetadata}
		alt={alt}
		inferSize={true}
		class="absolute inset-0 size-full object-cover transition duration-700 ease-[cubic-bezier(0.16,1,0.3,1)] group-hover:scale-[1.04]"
	/>
	<div class="absolute inset-0 bg-[linear-gradient(180deg,rgba(0,0,0,0)_0%,rgba(0,0,0,0.24)_48%,rgba(0,0,0,0.72)_100%)] transition duration-500 group-hover:opacity-90" />
	<div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.12),transparent_58%)] opacity-70" />
	<p class="absolute bottom-0 left-0 right-0 px-4 pb-4 text-[17px] font-medium leading-tight text-white drop-shadow-[0_2px_6px_rgba(0,0,0,0.8)] sm:text-[19px]">
		{title}
	</p>
</a>