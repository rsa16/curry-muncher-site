---
import { useStoryblokApi } from '@storyblok/astro';
import BaseLayout from "@layouts/BaseLayout.astro";
import ReportHeader from "@components/error-report/ReportHeader.astro";
import ErrorReportForm from "@components/error-report/ErrorReportForm.astro";
import { getNovelSlug, getVolumeSlug, type ChapterStory, type NovelStory, type VolumeStory } from "@lib/storyblok-novels";

type SeriesOption = {
	value: string;
	label: string;
};

type VolumeOption = {
	value: string;
	label: string;
};

type ChapterOption = {
	value: string;
	label: string;
};

const storyblokApi = useStoryblokApi();

const [novelStories, volumeStories, chapterStories] = await Promise.all([
	storyblokApi.getAll('cdn/stories', {
		content_type: 'Novel',
		starts_with: 'novels/',
		version: 'published',
		sort_by: 'name:asc'
	}) as Promise<NovelStory[]>,
	storyblokApi.getAll('cdn/stories', {
		content_type: 'Volume',
		starts_with: 'novels/',
		version: 'published',
		sort_by: 'content.sortOrder:asc'
	}) as Promise<VolumeStory[]>,
	storyblokApi.getAll('cdn/stories', {
		content_type: 'Chapter',
		starts_with: 'novels/',
		version: 'published',
		sort_by: 'content.chapterIndex:asc'
	}) as Promise<ChapterStory[]>
]);

const seriesOptions: SeriesOption[] = novelStories.map((novel) => ({
	value: novel.slug,
	label: novel.content.name
}));

const volumeOptionsBySeries = volumeStories.reduce<Record<string, VolumeOption[]>>((acc, volume) => {
	const novelSlug = getNovelSlug(volume.full_slug);
	if (!novelSlug) return acc;

	if (!acc[novelSlug]) {
		acc[novelSlug] = [];
	}

	acc[novelSlug].push({
		value: volume.slug,
		label: volume.content.displayName
	});

	return acc;
}, {});

const chaptersBySeriesVolume = chapterStories.reduce<Record<string, ChapterOption[]>>((acc, chapter) => {
	const novelSlug = getNovelSlug(chapter.full_slug);
	const volumeSlug = getVolumeSlug(chapter.full_slug);
	if (!novelSlug || !volumeSlug) return acc;

	const volumeKey = `${novelSlug}/${volumeSlug}`;

	if (!acc[volumeKey]) {
		acc[volumeKey] = [];
	}

	acc[volumeKey].push({
		value: chapter.slug,
		label: `${chapter.content.displayName}: ${chapter.content.chapterTitle}`
	});

	return acc;
}, {});

const imgbbApiKey = import.meta.env.PUBLIC_IMGBB_API_KEY;
const publicWorkerUrl = import.meta.env.PUBLIC_WORKER_URL;
---

<BaseLayout title="Curry Muncher Translations | Error Report">
	<div class="mx-4 pb-12 pt-8 sm:mx-6 sm:pt-10 lg:mx-24 2xl:mx-48">
		<div class="mx-auto flex w-full flex-col gap-8 sm:gap-10">
			<ReportHeader />
			<ErrorReportForm
				seriesOptions={seriesOptions}
				volumeOptionsBySeries={volumeOptionsBySeries}
				chaptersBySeriesVolume={chaptersBySeriesVolume}
				imgbbApiKey={imgbbApiKey}
				publicWorkerUrl={publicWorkerUrl}
			/>
		</div>
	</div>
</BaseLayout>