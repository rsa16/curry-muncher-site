---
import { Image } from "astro:assets";
import type { Affiliate } from "@data/home";

const { affiliates } = Astro.props as { affiliates: Affiliate[] };
---


<section class="section">
	<h2 class="text-3xl font-semibold text-white md:text-2xl">Afilliates</h2>
	<div class="affiliate-list mt-4 grid gap-3 sm:grid-cols-2">
		{affiliates.map((affiliate) => (
			<a href={affiliate.url} class="affiliate-card group relative flex w-full cursor-pointer items-center gap-3 overflow-hidden rounded-2xl bg-white/5 px-4 py-6 text-left backdrop-blur transition hover:bg-white/10 duration-200">
				<Image
					src={affiliate.image}
					alt={affiliate.name}
					class="absolute inset-0 h-full w-full object-cover opacity-80 transition duration-300 group-hover:opacity-100"
				/>
				<span class="pointer-events-none absolute inset-0 bg-gradient-to-r from-black/70 to-transparent opacity-100 transition duration-300 group-hover:opacity-70"></span>
				{affiliate.logo ? (
					<span class="relative z-10 flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-full bg-white/10 ring-1 ring-white/20">
						<Image src={affiliate.logo} alt={`${affiliate.name} logo`} class="object-cover" />
					</span>
				) : (
					<span class="relative z-10 flex h-8 w-8 shrink-0 items-center justify-center rounded-full bg-white/10 text-xs font-semibold text-white/90 ring-1 ring-white/20">
						{affiliate.name.slice(0, 1)}
					</span>
				)}
				<span class="relative z-10 text-lg font-semibold tracking-wide text-white drop-shadow sm:text-base">
					{affiliate.name}
				</span>
				<span class="affiliate-arrow relative z-10 ml-auto inline-flex h-7 w-7 items-center justify-center rounded-full bg-white/20 text-white/80 ring-1 ring-white/15 transition group-hover:bg-white/20 group-hover:text-white after:content-['>'] after:text-lg after:leading-none"></span>
			</a>
		))}
	</div>
</section>
