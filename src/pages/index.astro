---
import { useStoryblokApi } from '@storyblok/astro';
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/home/Hero.astro";
import LatestChapters from "@components/home/LatestChapters.astro";
import StaffSection from "@components/home/StaffSection.astro";
import AffiliatesSection from "@components/home/AffiliatesSection.astro";
import InfoSplit from "@components/home/InfoSplit.astro";

import { series as fallbackSeries, affiliates, staff, type Series } from "@data/home";
import {
	buildChapterRoute,
	getNovelSlug,
	getVolumeSlug,
	resolveStoryblokAsset,
	toPublicChapterSlug,
	type ChapterStory,
	type NovelStory,
} from "@lib/storyblok-novels";

type LatestChapterCard = {
	series: string;
	chapter: string;
	title: string;
	href: string;
};

const storyblokApi = useStoryblokApi();
const novelStories = (await storyblokApi.getAll('cdn/stories', {
	content_type: 'Novel',
	starts_with: 'novels/',
	version: 'published',
	sort_by: 'first_published_at:desc'
})) as NovelStory[];

const storyblokSeries: Series[] = novelStories.reduce<Series[]>((acc, story) => {
	const cover = resolveStoryblokAsset(story.content.coverImage) ?? resolveStoryblokAsset(story.content.bannerImage);
	if (!cover) return acc;

	acc.push({
		cover,
		alt: `${story.content.name} cover`,
		title: story.content.name,
		href: `/novels/${story.slug}`,
	});

	return acc;
}, []);

const series = storyblokSeries.length > 0 ? storyblokSeries : fallbackSeries;
const novelTitleBySlug = new Map(novelStories.map((story) => [story.slug, story.content.name]));

const chapterStories = (await storyblokApi.getAll('cdn/stories', {
	content_type: 'Chapter',
	starts_with: 'novels/',
	version: 'published',
	sort_by: 'first_published_at:desc'
})) as ChapterStory[];

const latestChapters: LatestChapterCard[] = chapterStories.slice(0, 6).map((chapter) => {
	const novelSlug = getNovelSlug(chapter.full_slug);
	const volumeSlug = getVolumeSlug(chapter.full_slug);

	return {
		series: novelTitleBySlug.get(novelSlug),
		chapter: chapter.content.displayName,
		title: chapter.content.chapterTitle,
		href: buildChapterRoute(novelSlug, volumeSlug, toPublicChapterSlug(volumeSlug, chapter.slug)),
	};
});
---

<BaseLayout title="Curry Muncher Translations">
	<Hero series={series}/>

	<div class="z-150 mx-4 mt-12 mb-12 flex flex-col gap-14 sm:mx-6 md:mx-12 lg:mx-24 2xl:mx-48">
		<LatestChapters chapters={latestChapters} />
		<AffiliatesSection affiliates={affiliates} />
		<StaffSection staff={staff} />
		<InfoSplit />
	</div>

</BaseLayout>