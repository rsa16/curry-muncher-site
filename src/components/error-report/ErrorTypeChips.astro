---
export interface Props {
	options: string[];
}

const { options } = Astro.props;
---

<div class="flex flex-wrap gap-2" data-error-type-group>
	{options.map((option) => (
		<button
			type="button"
			class="rounded-[11px] bg-white/10 px-4 py-1 text-[18px] font-medium text-[#bc9999] transition hover:bg-white/15"
			data-error-type-option={option}
		>
			{option}
		</button>
	))}
</div>
