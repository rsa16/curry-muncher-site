---
import { renderRichText } from '@storyblok/astro';
import { Image } from 'astro:assets';
import { type VolumeChangelogEntryBlock, type VolumeChapterLink, type VolumeContent } from '@lib/storyblok-novels';

interface Props {
	blok: VolumeContent;
	chapters: VolumeChapterLink[];
	illustrationAssets: string[];
	changelogEntries: VolumeChangelogEntryBlock[];
}

const { blok, chapters, illustrationAssets, changelogEntries } = Astro.props as Props;
const synopsisHtml = renderRichText(blok.synopsis as any);
const translatorsNoteHtml = blok.translatorsNote ? renderRichText(blok.translatorsNote as any) : '';
const illustrationMeta = illustrationAssets.map((asset, index) => ({
	src: asset,
	alt: `${blok.displayName} illustration ${index + 1}`,
}));
---

<section class="flex w-full flex-1 flex-col gap-[15px] xl:max-w-[571px]">
	<div class="rounded-[15px] bg-[rgba(255,255,255,0.1)] p-5">
		<p class="text-[18px] font-semibold uppercase leading-[1.2] text-[#b9b9b9]">Synopsis</p>
		<div class="mt-2 text-[15px] leading-[1.25] text-[#dfdfdf]" set:html={synopsisHtml}></div>
	</div>

	<div data-volume-tabs class="flex flex-col gap-4 mb-2 rounded-[15px]">
		<div role="tablist" aria-label="Volume sections" class="grid grid-cols-3 rounded-[10px] bg-[rgba(255,255,255,0.15)] p-[5px] text-center text-[clamp(11px,3vw,16px)] font-medium">
			<button type="button" role="tab" aria-selected="true" data-volume-tab="chapters" class="w-full rounded-[10px] bg-[#525252] px-[8px] py-[6px] text-white transition sm:px-[15px] sm:py-[5px]">Chapters</button>
			<button type="button" role="tab" aria-selected="false" data-volume-tab="illustrations" class="w-full rounded-[10px] px-[8px] py-[6px] text-[#808080] transition hover:text-white sm:px-[15px] sm:py-[5px]">Illustrations</button>
			<button type="button" role="tab" aria-selected="false" data-volume-tab="changelog" class="w-full rounded-[10px] px-[8px] py-[6px] text-[#808080] transition hover:text-white sm:px-[15px] sm:py-[5px]">Changelog</button>
		</div>

		<div class="space-y-[5px] overflow-y-auto pr-1" data-volume-tab-panel="chapters" role="tabpanel">
			{chapters.length ? chapters.map((chapter, index) => (
				<a href={chapter.href} class="block rounded-[10px] bg-[rgba(217,217,217,0.1)] px-3 py-[7px] text-[14px] leading-[1.46] text-white transition hover:bg-[rgba(217,217,217,0.16)]">
					{index + 1}. {chapter.name}
				</a>
			)) : <div class="rounded-[10px] bg-[rgba(217,217,217,0.1)] px-3 py-[7px] text-[14px] text-white/60">No chapters published yet.</div>}
		</div>

		<div class="hidden space-y-3" data-volume-tab-panel="illustrations" role="tabpanel">
			{illustrationAssets.length ? (
				<div class="grid gap-3 sm:grid-cols-2">
					{illustrationMeta.map((illustration, index) => (
						<button
							type="button"
							data-illustration-open={index}
							aria-label={`Open ${illustration.alt}`}
							class="group overflow-hidden rounded-[15px] bg-[rgba(217,217,217,0.1)] text-left transition ease-out duration-300 hover:cursor-pointer hover:brightness-75"
						>
							<Image inferSize={true} src={illustration.src} alt={illustration.alt} loading="lazy" class="h-full w-full object-cover transition-transform ease-out duration-300 group-hover:scale-[1.03]" />
						</button>
					))}
				</div>
			) : (
				<div class="rounded-[10px] bg-[rgba(217,217,217,0.1)] px-3 py-[7px] text-[14px] text-white/60">No illustrations available yet.</div>
			)}
		</div>

		<div class="hidden space-y-3" data-volume-tab-panel="changelog" role="tabpanel">
			{changelogEntries.length ? (
				changelogEntries.map((entry) => (
					<div class="rounded-[10px] bg-[rgba(217,217,217,0.1)] px-3 py-[10px] text-[14px] leading-[1.46] text-white">
						<p><strong>{entry.version}</strong> - {entry.shortTitle}</p>
						{entry.date ? <p class="text-white/65">{entry.date}</p> : null}
						{entry.description ? <p class="text-white/80">{entry.description}</p> : null}
					</div>
				))
			) : (
				<div class="rounded-[10px] bg-[rgba(217,217,217,0.1)] px-3 py-[7px] text-[14px] text-white/60">No changelog entries yet.</div>
			)}
		</div>
	</div>

	{illustrationMeta.length ? (
		<div class="fixed inset-0 z-[90] hidden items-center justify-center bg-black/0 px-4 py-10 opacity-0 transition-[opacity,background-color] duration-300 ease-out sm:py-12 lg:py-14" data-illustration-modal>
			<div class="absolute inset-0 bg-black/0 transition-colors duration-300 ease-out" data-illustration-backdrop></div>
			<div class="relative flex w-full max-w-[1320px] items-center justify-center gap-3">
				<button type="button" class="absolute right-0 top-0 z-20 inline-flex h-10 w-10 items-center justify-center rounded-full bg-black/55 text-white/90 shadow-[0_8px_30px_rgba(0,0,0,0.4)] transition ease-out duration-200 hover:bg-black/75" data-illustration-close aria-label="Close illustration viewer">
					<span class="text-[24px] leading-none">x</span>
				</button>

				<button type="button" class="z-20 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-black/55 text-white/90 shadow-[0_8px_30px_rgba(0,0,0,0.4)] transition ease-out duration-200 hover:bg-black/75 disabled:cursor-not-allowed disabled:opacity-40" data-illustration-prev aria-label="Previous illustration">
					<svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"></path></svg>
				</button>

				<div class="relative max-h-[80vh] w-full overflow-hidden rounded-[18px] bg-black/30 shadow-[0_25px_80px_rgba(0,0,0,0.55)] ring-1 ring-white/10">
					<div class="absolute inset-0 bg-black/20"></div>
					<div class="relative flex min-h-[240px] items-center justify-center">
						<img src={illustrationMeta[0].src} alt={illustrationMeta[0].alt} class="max-h-[80vh] w-full object-contain" data-illustration-image />
					</div>
				</div>

				<button type="button" class="z-20 inline-flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-black/55 text-white/90 shadow-[0_8px_30px_rgba(0,0,0,0.4)] transition ease-out duration-200 hover:bg-black/75 disabled:cursor-not-allowed disabled:opacity-40" data-illustration-next aria-label="Next illustration">
					<svg viewBox="0 0 24 24" class="size-5" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"></path></svg>
				</button>
			</div>
		</div>
	) : null}

	<div class="min-h-[20vh] rounded-[15px] bg-[rgba(255,255,255,0.1)] p-[15px]">
		<p class="text-[17px] font-medium leading-[1.46] text-[#b9b9b9]">Translator’s Note</p>
		{translatorsNoteHtml ? (
			<div class="mt-2 text-[14px] leading-[1.46] text-white/90" set:html={translatorsNoteHtml}></div>
		) : (
			<p class="mt-2 text-[14px] leading-[1.46] text-white/55">No translator note yet.</p>
		)}
	</div>
</section>

<script is:inline>
	const setupVolumeTabs = () => {
		const root = document.querySelector('[data-volume-tabs]');
		if (!root) return;

		const illustrationButtons = Array.from(root.querySelectorAll('[data-illustration-open]'));
		const modal = document.querySelector('[data-illustration-modal]');
		const backdrop = document.querySelector('[data-illustration-backdrop]');
		const panelImage = modal?.querySelector('[data-illustration-image]');
		const closeButton = modal?.querySelector('[data-illustration-close]');
		const prevButton = modal?.querySelector('[data-illustration-prev]');
		const nextButton = modal?.querySelector('[data-illustration-next]');

		const illustrations = [
			...root.querySelectorAll('[data-illustration-open]')
		].map((button) => {
			const index = Number(button.getAttribute('data-illustration-open'));
			const image = button.querySelector('img');
			return {
				index: Number.isNaN(index) ? 0 : index,
				src: image?.getAttribute('src') ?? '',
				alt: image?.getAttribute('alt') ?? 'Illustration',
			};
		}).sort((left, right) => left.index - right.index);

		let activeIndex = 0;

		const setupIllustrationModal = () => {
			if (!modal || !panelImage || !illustrations.length) {
				return;
			}
			let isClosing = false;

		const updateNavigationState = () => {
			const hasMultiple = illustrations.length > 1;
			prevButton?.toggleAttribute('disabled', !hasMultiple);
			nextButton?.toggleAttribute('disabled', !hasMultiple);
		};

		const setActiveIllustration = (index) => {
			activeIndex = (index + illustrations.length) % illustrations.length;
			const active = illustrations[activeIndex];
			panelImage.setAttribute('src', active.src);
			panelImage.setAttribute('alt', active.alt);
			updateNavigationState();
		};

		const animateOpen = () => {
			modal.style.opacity = '1';
			if (backdrop) backdrop.style.backgroundColor = 'rgba(0, 0, 0, 0.82)';
			if (panelImage) {
				panelImage.classList.remove('opacity-0', 'scale-[0.92]');
				panelImage.classList.add('opacity-100', 'scale-100');
			}
		};

		const animateClose = () => {
			modal.style.opacity = '0';
			if (backdrop) backdrop.style.backgroundColor = 'rgba(0, 0, 0, 0)';
			if (panelImage) {
				panelImage.classList.remove('opacity-100', 'scale-100');
				panelImage.classList.add('opacity-0', 'scale-[0.92]');
			}
		};

		const openModal = (index) => {
			if (isClosing) return;
			setActiveIllustration(index);
			modal.classList.remove('hidden');
			modal.classList.add('flex');
			requestAnimationFrame(animateOpen);
		};

		const closeModal = () => {
			if (isClosing || modal.classList.contains('hidden')) return;
			isClosing = true;
			animateClose();
			window.setTimeout(() => {
				modal.classList.add('hidden');
				modal.classList.remove('flex');
				isClosing = false;
			}, 300);
		};

		illustrationButtons.forEach((button) => {
			button.addEventListener('click', () => {
				openModal(Number(button.getAttribute('data-illustration-open') ?? '0'));
			});
		});

		closeButton?.addEventListener('click', closeModal);
		backdrop?.addEventListener('click', closeModal);
		prevButton?.addEventListener('click', () => setActiveIllustration(activeIndex - 1));
		nextButton?.addEventListener('click', () => setActiveIllustration(activeIndex + 1));

		document.addEventListener('keydown', (event) => {
			if (modal.classList.contains('hidden')) return;

			if (event.key === 'Escape') {
				closeModal();
				return;
			}

			if (event.key === 'ArrowLeft') {
				setActiveIllustration(activeIndex - 1);
			}

			if (event.key === 'ArrowRight') {
				setActiveIllustration(activeIndex + 1);
			}
		});

		updateNavigationState();
		};

		setupIllustrationModal();

		const tabs = Array.from(root.querySelectorAll('[data-volume-tab]'));
		const panels = Array.from(root.querySelectorAll('[data-volume-tab-panel]'));

		const setActive = (name) => {
			tabs.forEach((tab) => {
				const active = tab.getAttribute('data-volume-tab') === name;
				tab.setAttribute('aria-selected', String(active));
				tab.classList.toggle('bg-[#525252]', active);
				tab.classList.toggle('text-white', active);
				tab.classList.toggle('text-[#808080]', !active);
			});

			panels.forEach((panel) => {
				panel.classList.toggle('hidden', panel.getAttribute('data-volume-tab-panel') !== name);
			});
		};

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => setActive(tab.getAttribute('data-volume-tab') ?? 'chapters'));
		});

		setActive('chapters');
	};

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', setupVolumeTabs, { once: true });
	} else {
		setupVolumeTabs();
	}
</script>