---
import BaseLayout from "@layouts/BaseLayout.astro";
import Hero from "@components/Hero.astro";
import LatestChapters from "@components/LatestChapters.astro";
import StaffSection from "@components/StaffSection.astro";
import AffiliatesSection from "@components/AffiliatesSection.astro";
import InfoSplit from "@components/InfoSplit.astro";

import { affiliates, chapters, staff } from "@data/home";
---

<BaseLayout title="Curry Muncher Translations">
	<Hero />

	<LatestChapters chapters={chapters} />
	<StaffSection staff={staff} />
	<AffiliatesSection affiliates={affiliates} />
	
	<InfoSplit />
</BaseLayout>