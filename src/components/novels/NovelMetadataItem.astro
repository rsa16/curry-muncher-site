---
interface Props {
    label: string;
    value: string;
}

const { label, value } = Astro.props as Props;
---

<div class="relative h-auto min-w-0 sm:h-[51px] sm:min-w-[94px]">
    <p class="text-[14px] font-semibold leading-[1.25] text-white">{label}</p>
    <p class="mt-1 inline-flex min-h-[30px] max-w-full items-center rounded-[15px] bg-white/16 px-[10px] py-[5px] text-[16px] font-light leading-[1.249] text-white">
        {value}
    </p>
</div>
