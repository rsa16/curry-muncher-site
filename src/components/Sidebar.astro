---
import { Icon } from "astro-icon/components";

const navItems = [
	{ label: "Home", href: "/", icon: "lucide:home", position: "top" },
	{ label: "Series", href: "/series", icon:"lucide:library", position: "top"},
	{ label: "Staff", href: "/staff", icon:"lucide:users", position: "top"},
	{ label: "About", href: "/about", icon:"lucide:info", position: "top"},
	
	{ label: "Contact Us", href: "/contact-us", icon: "lucide:mail", position: "bottom" },
	{ label: "FAQ", href: "/faq", icon: "lucide:circle-question-mark", position: "bottom" },
];

const isActive = (href: string) => Astro.url.pathname === href;
---

<aside
	class="sidebar text-[#F8DCAD] z-2000 sticky left-0 top-0 hidden h-screen flex-col bg-sidebar px-2 py-3 md:flex"
	aria-label="Sidebar"
>
	<button class="icon-button sidebar-toggle" aria-label="Open menu" aria-expanded="false" type="button">
		<span class="sidebar-icon" aria-hidden="true">
			<Icon name="lucide:sidebar-open" size={18}></Icon>
		</span>
		<span class="sidebar-label ml-3 sidebar-toggle-label">Open</span>
	</button>

	<nav class="sidebar-top mt-8 flex-grow" aria-label="Main">
		{navItems
			.filter((item) => item.position === "top")
			.map((item) => (
				<a
					class={`sidebar-item ${isActive(item.href) ? "is-active" : ""}`}
					href={item.href}
					aria-current={isActive(item.href) ? "page" : undefined}
				>
					<span class="sidebar-icon" aria-hidden="true">
						<Icon name={item.icon} size={18}></Icon>
					</span>
					<span class="sidebar-label">{item.label}</span>
				</a>
			))}
	</nav>
	<div class="sidebar-bottom">
		{navItems
			.filter((item) => item.position === "bottom")
			.map((item) => (
				<a
					class={`sidebar-item ${isActive(item.href) ? "is-active" : ""}`}
					href={item.href}
					aria-current={isActive(item.href) ? "page" : undefined}
				>
					<span class="sidebar-icon" aria-hidden="true">
						<Icon name={item.icon} size={18}></Icon>
					</span>
					<span class="sidebar-label">{item.label}</span>
				</a>
			))}
	</div>
</aside>

<script type="module">
	const sidebar = document.querySelector(".sidebar");
	const toggle = document.querySelector(".sidebar-toggle");

	if (sidebar && toggle) {
		const setExpanded = (expanded) => {
			sidebar.classList.toggle("is-expanded", expanded);
			toggle.setAttribute("aria-expanded", String(expanded));
			const label = toggle.querySelector(".sidebar-toggle-label");
			if (label) {
				label.textContent = expanded ? "Close" : "Open";
			}
		};

		toggle.addEventListener("click", () => {
			setExpanded(!sidebar.classList.contains("is-expanded"));
		});
	}
</script>
