---
import RequiredMark from "@components/error-report/RequiredMark.astro";
import ErrorTypeChips from "@components/error-report/ErrorTypeChips.astro";

export interface VolumeOption {
	value: string;
	label: string;
}

export interface SeriesOption {
	value: string;
	label: string;
}

export interface ChapterOption {
	value: string;
	label: string;
}

export interface Props {
	seriesOptions: SeriesOption[];
	volumeOptionsBySeries: Record<string, VolumeOption[]>;
	chaptersBySeriesVolume: Record<string, ChapterOption[]>;
	imgbbApiKey?: string;
	publicWorkerUrl?: string;
}

const { seriesOptions, volumeOptionsBySeries, chaptersBySeriesVolume, imgbbApiKey, publicWorkerUrl } = Astro.props;
const errorTypes = ["Typo", "Grammar", "Translation", "Wrong Term", "Formatting"];
---

<div class="mx-auto w-full max-w-[776px]" data-report-root>
	<div class="rounded-[20px] bg-[#2c1f1f] p-6 sm:p-8" data-form-shell>
		<p class="mb-6 text-[18px] text-[#c7a0a0]">
			Surprise, we are human and make mistakes! We aren&apos;t machines (...unlike <span class="italic">some</span>
			groups) and are prone to typos or grammar issues, or being inconsistent at times. Please make sure to verify that
			you have the latest version of the translation before reporting!
		</p>

		<form class="space-y-6" data-error-report-form novalidate>
			<input type="hidden" name="errorType" data-error-type-input />
			<input type="hidden" name="attachmentUrl" data-attachment-url-input />
			<div>
				<label for="series" class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Series<RequiredMark /></label>
				<div class="relative">
					<select
						id="series"
						name="series"
						class="sr-only"
						data-series-select
					>
						<option value="">Select Series</option>
						{seriesOptions.map((series) => (
							<option value={series.value}>{series.label}</option>
						))}
					</select>
					<button
						type="button"
						class="flex h-[47px] w-full items-center justify-between rounded-[9px] bg-[#413535] px-4 pr-3 text-left text-[18px] text-[#c7a0a0] outline-none ring-[#d69595] transition focus:ring-2"
						data-custom-select-trigger="series"
						data-placeholder="Select Series"
						aria-haspopup="listbox"
						aria-expanded="false"
					>
						<span data-custom-select-label="series">Select Series</span>
						<span class="text-[#a88181] transition" data-custom-select-caret="series">▾</span>
					</button>
					<div
						class="pointer-events-none absolute left-0 right-0 top-[calc(100%+8px)] z-30 translate-y-1 scale-[0.98] opacity-0 transition duration-150 ease-out"
						data-custom-select-popover="series"
						hidden
					>
						<div class="max-h-56 overflow-auto rounded-[10px] border border-white/10 bg-[#3a2d2d] p-1 shadow-[0_14px_40px_rgba(0,0,0,0.35)]" data-custom-select-list="series"></div>
					</div>
				</div>
			</div>

			<div>
				<label for="volume" class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Volume<RequiredMark /></label>
				<div class="relative">
					<select
						id="volume"
						name="volume"
						class="sr-only"
						data-volume-select
						disabled
					>
						<option value="">Select Volume</option>
					</select>
					<button
						type="button"
						class="flex h-[47px] w-full items-center justify-between rounded-[9px] bg-[#413535] px-4 pr-3 text-left text-[18px] text-[#c7a0a0] outline-none ring-[#d69595] transition focus:ring-2 disabled:cursor-not-allowed disabled:opacity-70"
						data-custom-select-trigger="volume"
						data-placeholder="Select Volume"
						aria-haspopup="listbox"
						aria-expanded="false"
						disabled
					>
						<span data-custom-select-label="volume">Select Volume</span>
						<span class="text-[#a88181] transition" data-custom-select-caret="volume">▾</span>
					</button>
					<div
						class="pointer-events-none absolute left-0 right-0 top-[calc(100%+8px)] z-30 translate-y-1 scale-[0.98] opacity-0 transition duration-150 ease-out"
						data-custom-select-popover="volume"
						hidden
					>
						<div class="max-h-56 overflow-auto rounded-[10px] border border-white/10 bg-[#3a2d2d] p-1 shadow-[0_14px_40px_rgba(0,0,0,0.35)]" data-custom-select-list="volume"></div>
					</div>
				</div>
			</div>

			<div>
				<label for="chapter" class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Chapter<RequiredMark /></label>
				<div class="relative">
					<select
						id="chapter"
						name="chapter"
						class="sr-only"
						data-chapter-select
						disabled
					>
						<option value="">Select Chapter</option>
					</select>
					<button
						type="button"
						class="flex h-[47px] w-full items-center justify-between rounded-[9px] bg-[#413535] px-4 pr-3 text-left text-[18px] text-[#c7a0a0] outline-none ring-[#d69595] transition focus:ring-2 disabled:cursor-not-allowed disabled:opacity-70"
						data-custom-select-trigger="chapter"
						data-placeholder="Select Chapter"
						aria-haspopup="listbox"
						aria-expanded="false"
						disabled
					>
						<span data-custom-select-label="chapter">Select Chapter</span>
						<span class="text-[#a88181] transition" data-custom-select-caret="chapter">▾</span>
					</button>
					<div
						class="pointer-events-none absolute left-0 right-0 top-[calc(100%+8px)] z-30 translate-y-1 scale-[0.98] opacity-0 transition duration-150 ease-out"
						data-custom-select-popover="chapter"
						hidden
					>
						<div class="max-h-56 overflow-auto rounded-[10px] border border-white/10 bg-[#3a2d2d] p-1 shadow-[0_14px_40px_rgba(0,0,0,0.35)]" data-custom-select-list="chapter"></div>
					</div>
				</div>
			</div>

			<div class="hidden space-y-6" data-dependent-fields>
				<div>
					<p class="mb-2 block text-[18px] font-semibold text-[#e4abab]">What type of error is it?<RequiredMark /></p>
					<ErrorTypeChips options={errorTypes} />
				</div>

				<div>
					<label for="passage" class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Passage<RequiredMark /></label>
					<textarea
						id="passage"
						name="passage"
						rows={7}
						placeholder="Please provide the exact passage with the error..."
						class="w-full rounded-[9px] bg-[#413535] px-4 py-3 text-[18px] text-[#c7a0a0] outline-none ring-[#d69595] transition placeholder:text-[#947474] focus:ring-2"
						data-passage-input
					></textarea>
				</div>

				<div>
					<label for="contact" class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Contact</label>
					<input
						id="contact"
						name="contact"
						type="text"
						placeholder="Discord Username or Email"
						class="h-[48px] w-full rounded-[9px] bg-[#413535] px-4 text-[18px] text-[#c7a0a0] outline-none ring-[#d69595] transition placeholder:text-[#947474] focus:ring-2"
					/>
				</div>

				<div>
					<p class="mb-2 block text-[18px] font-semibold text-[#e4abab]">Attachment</p>
					<div
						class="flex h-[189px] w-full cursor-pointer items-center justify-center rounded-[10px] border-2 border-dashed border-white/15 text-center transition hover:border-white/25"
						data-attachment-dropzone
						tabindex="0"
					>
						<div data-attachment-empty>
							<p class="text-[18px] text-[#947474]">Paste Image</p>
							<p class="text-[14px] text-[#694f4f]">(optional)</p>
							<p class="mt-2 text-[13px] text-[#7f5f5f]">Click, drop, or paste to upload</p>
						</div>
						<div class="hidden h-full w-full p-3" data-attachment-preview>
							<div class="relative h-full w-full overflow-hidden rounded-[8px] border border-white/10 bg-black/20">
								<img
									alt="Uploaded attachment"
									class="h-full w-full object-contain"
									data-attachment-preview-image
								/>
								<button
									type="button"
									class="absolute right-2 top-2 rounded-md bg-[#2c1f1f]/90 px-2 py-1 text-xs font-medium text-[#ffd0d0] ring-1 ring-white/20 transition hover:bg-[#472f2f]"
									data-attachment-clear
								>
									Remove
								</button>
							</div>
						</div>
					</div>
					<input class="hidden" type="file" accept="image/*" data-attachment-file-input />
					<p class="mt-2 min-h-5 text-[14px] text-[#b99191]" data-attachment-status></p>
				</div>
			</div>

			<div class="flex flex-col gap-3 pt-2 sm:flex-row" data-action-row>
				<button
					type="submit"
					class="h-[64px] flex-1 rounded-[20px] bg-[#725858] text-[20px] font-medium text-[#d7bbbb] transition"
					data-submit-button
					disabled
				>
					Submit
				</button>
				<button
					type="button"
					class="h-[64px] rounded-[20px] bg-[#2c1f1f] px-7 text-[20px] font-medium text-[#a37c7c] ring-1 ring-white/5 transition hover:bg-[#382828]"
					data-reset-button
				>
					Reset
				</button>
			</div>
		</form>
	</div>

	<div class="hidden rounded-[20px] bg-[#2c1f1f] px-6 py-16 text-center sm:px-8" data-thank-you>
		<p class="text-[28px] font-semibold text-[#ffd0d0]">Thank you for the report!</p>
	</div>
</div>

<script
	type="application/json"
	id="error-report-config"
	set:html={JSON.stringify({ volumeOptionsBySeries, chaptersBySeriesVolume, imgbbApiKey, publicWorkerUrl })}
></script>

<script>
	const root = document.querySelector("[data-report-root]");
	if (!root) {
		throw new Error("Error report root not found.");
	}

	const configElement = document.getElementById("error-report-config");
	if (!(configElement instanceof HTMLScriptElement)) {
		throw new Error("Missing error report config.");
	}

	const config = JSON.parse(configElement.textContent || "{}");
	const volumeOptionsBySeries = config.volumeOptionsBySeries || {};
	const chaptersBySeriesVolume = config.chaptersBySeriesVolume || {};
	const imgbbApiKey = config.imgbbApiKey || "";
	const publicWorkerUrl = config.publicWorkerUrl || "";

	const formShell = root.querySelector("[data-form-shell]");
	const thankYou = root.querySelector("[data-thank-you]");
	const form = root.querySelector("[data-error-report-form]");
	const seriesSelect = root.querySelector("[data-series-select]");
	const volumeSelect = root.querySelector("[data-volume-select]");
	const chapterSelect = root.querySelector("[data-chapter-select]");
	const seriesTrigger = root.querySelector("[data-custom-select-trigger='series']");
	const volumeTrigger = root.querySelector("[data-custom-select-trigger='volume']");
	const chapterTrigger = root.querySelector("[data-custom-select-trigger='chapter']");
	const seriesLabel = root.querySelector("[data-custom-select-label='series']");
	const volumeLabel = root.querySelector("[data-custom-select-label='volume']");
	const chapterLabel = root.querySelector("[data-custom-select-label='chapter']");
	const seriesCaret = root.querySelector("[data-custom-select-caret='series']");
	const volumeCaret = root.querySelector("[data-custom-select-caret='volume']");
	const chapterCaret = root.querySelector("[data-custom-select-caret='chapter']");
	const seriesPopover = root.querySelector("[data-custom-select-popover='series']");
	const volumePopover = root.querySelector("[data-custom-select-popover='volume']");
	const chapterPopover = root.querySelector("[data-custom-select-popover='chapter']");
	const seriesList = root.querySelector("[data-custom-select-list='series']");
	const volumeList = root.querySelector("[data-custom-select-list='volume']");
	const chapterList = root.querySelector("[data-custom-select-list='chapter']");
	const dependentFields = root.querySelector("[data-dependent-fields]");
	const passageInput = root.querySelector("[data-passage-input]");
	const errorTypeInput = root.querySelector("[data-error-type-input]");
	const errorTypeOptions = Array.from(root.querySelectorAll("[data-error-type-option]"));
	const submitButton = root.querySelector("[data-submit-button]");
	const resetButton = root.querySelector("[data-reset-button]");
	const dropzone = root.querySelector("[data-attachment-dropzone]");
	const attachmentEmpty = root.querySelector("[data-attachment-empty]");
	const attachmentPreview = root.querySelector("[data-attachment-preview]");
	const attachmentPreviewImage = root.querySelector("[data-attachment-preview-image]");
	const attachmentClearButton = root.querySelector("[data-attachment-clear]");
	const fileInput = root.querySelector("[data-attachment-file-input]");
	const attachmentStatus = root.querySelector("[data-attachment-status]");
	const attachmentUrlInput = root.querySelector("[data-attachment-url-input]");

	if (
		!(formShell instanceof HTMLElement) ||
		!(thankYou instanceof HTMLElement) ||
		!(form instanceof HTMLFormElement) ||
		!(seriesSelect instanceof HTMLSelectElement) ||
		!(volumeSelect instanceof HTMLSelectElement) ||
		!(chapterSelect instanceof HTMLSelectElement) ||
		!(seriesTrigger instanceof HTMLButtonElement) ||
		!(volumeTrigger instanceof HTMLButtonElement) ||
		!(chapterTrigger instanceof HTMLButtonElement) ||
		!(seriesLabel instanceof HTMLElement) ||
		!(volumeLabel instanceof HTMLElement) ||
		!(chapterLabel instanceof HTMLElement) ||
		!(seriesCaret instanceof HTMLElement) ||
		!(volumeCaret instanceof HTMLElement) ||
		!(chapterCaret instanceof HTMLElement) ||
		!(seriesPopover instanceof HTMLElement) ||
		!(volumePopover instanceof HTMLElement) ||
		!(chapterPopover instanceof HTMLElement) ||
		!(seriesList instanceof HTMLElement) ||
		!(volumeList instanceof HTMLElement) ||
		!(chapterList instanceof HTMLElement) ||
		!(dependentFields instanceof HTMLElement) ||
		!(passageInput instanceof HTMLTextAreaElement) ||
		!(errorTypeInput instanceof HTMLInputElement) ||
		!(submitButton instanceof HTMLButtonElement) ||
		!(resetButton instanceof HTMLButtonElement) ||
		!(dropzone instanceof HTMLElement) ||
		!(attachmentEmpty instanceof HTMLElement) ||
		!(attachmentPreview instanceof HTMLElement) ||
		!(attachmentPreviewImage instanceof HTMLImageElement) ||
		!(attachmentClearButton instanceof HTMLButtonElement) ||
		!(fileInput instanceof HTMLInputElement) ||
		!(attachmentStatus instanceof HTMLElement) ||
		!(attachmentUrlInput instanceof HTMLInputElement)
	) {
		throw new Error("Error report form is missing required elements.");
	}

	type SelectKey = "series" | "volume" | "chapter";
	type CustomSelectParts = {
		select: HTMLSelectElement;
		trigger: HTMLButtonElement;
		label: HTMLElement;
		caret: HTMLElement;
		popover: HTMLElement;
		list: HTMLElement;
		closeTimer?: number;
	};

	const customSelects: Record<SelectKey, CustomSelectParts> = {
		series: { select: seriesSelect, trigger: seriesTrigger, label: seriesLabel, caret: seriesCaret, popover: seriesPopover, list: seriesList },
		volume: { select: volumeSelect, trigger: volumeTrigger, label: volumeLabel, caret: volumeCaret, popover: volumePopover, list: volumeList },
		chapter: { select: chapterSelect, trigger: chapterTrigger, label: chapterLabel, caret: chapterCaret, popover: chapterPopover, list: chapterList },
	};

	let openSelectKey: SelectKey | null = null;

	const updateCustomLabel = (key: SelectKey) => {
		const parts = customSelects[key];
		const selectedOption = parts.select.options[parts.select.selectedIndex];
		const placeholder = parts.trigger.dataset.placeholder || "";
		parts.label.textContent = selectedOption?.value ? (selectedOption.textContent || placeholder) : placeholder;
	};

	const setPopoverOpen = (key: SelectKey, open: boolean) => {
		const parts = customSelects[key];
		if (parts.closeTimer) {
			window.clearTimeout(parts.closeTimer);
			parts.closeTimer = undefined;
		}

		parts.trigger.setAttribute("aria-expanded", String(open));
		parts.caret.classList.toggle("rotate-180", open);

		if (open) {
			parts.popover.hidden = false;
			requestAnimationFrame(() => {
				parts.popover.classList.remove("pointer-events-none", "opacity-0", "translate-y-1", "scale-[0.98]");
				parts.popover.classList.add("pointer-events-auto", "opacity-100", "translate-y-0", "scale-100");
			});
			return;
		}

		parts.popover.classList.remove("pointer-events-auto", "opacity-100", "translate-y-0", "scale-100");
		parts.popover.classList.add("pointer-events-none", "opacity-0", "translate-y-1", "scale-[0.98]");
		parts.closeTimer = window.setTimeout(() => {
			parts.popover.hidden = true;
		}, 150);
	};

	const closeAllSelects = () => {
		(Object.keys(customSelects) as SelectKey[]).forEach((key) => setPopoverOpen(key, false));
		openSelectKey = null;
	};

	const renderCustomOptions = (key: SelectKey) => {
		const parts = customSelects[key];
		parts.list.innerHTML = "";

		const options = Array.from(parts.select.options).filter((option) => option.value.length > 0);
		if (options.length === 0) {
			const empty = document.createElement("p");
			empty.className = "px-3 py-2 text-sm text-[#8b6969]";
			empty.textContent = "No options";
			parts.list.appendChild(empty);
			updateCustomLabel(key);
			return;
		}

		options.forEach((option) => {
			const button = document.createElement("button");
			button.type = "button";
			button.className = "mb-1 block w-full rounded-[8px] px-3 py-2 text-left text-[16px] transition";
			button.dataset.value = option.value;
			button.textContent = option.textContent || option.value;

			const isSelected = parts.select.value === option.value;
			button.classList.toggle("bg-[#594444]", isSelected);
			button.classList.toggle("text-[#ffd0d0]", isSelected);
			button.classList.toggle("text-[#c9a3a3]", !isSelected);
			button.classList.toggle("hover:bg-[#4b3939]", !isSelected);
			parts.list.appendChild(button);
		});

		updateCustomLabel(key);
	};

	const syncCustomSelect = (key: SelectKey) => {
		const parts = customSelects[key];
		parts.trigger.disabled = parts.select.disabled;
		renderCustomOptions(key);
		if (parts.select.disabled && openSelectKey === key) {
			closeAllSelects();
		}
	};

	(Object.keys(customSelects) as SelectKey[]).forEach((key) => {
		const parts = customSelects[key];

		parts.trigger.addEventListener("click", () => {
			if (parts.trigger.disabled) return;
			if (openSelectKey === key) {
				closeAllSelects();
				return;
			}

			closeAllSelects();
			setPopoverOpen(key, true);
			openSelectKey = key;
		});

		parts.trigger.addEventListener("keydown", (event) => {
			if (parts.trigger.disabled) return;
			if (event.key === "Enter" || event.key === " ") {
				event.preventDefault();
				parts.trigger.click();
			}
			if (event.key === "Escape") {
				closeAllSelects();
			}
		});

		parts.list.addEventListener("click", (event) => {
			const target = event.target;
			if (!(target instanceof HTMLElement)) return;
			const optionButton = target.closest("button[data-value]");
			if (!(optionButton instanceof HTMLButtonElement)) return;

			parts.select.value = optionButton.dataset.value || "";
			parts.select.dispatchEvent(new Event("change"));
			closeAllSelects();
		});
	});

	document.addEventListener("click", (event) => {
		if (!(event.target instanceof Node)) return;
		if (!root.contains(event.target)) {
			closeAllSelects();
		}
	});

	document.addEventListener("keydown", (event) => {
		if (event.key === "Escape") {
			closeAllSelects();
		}
	});

	const syncAttachmentPreview = (url: string) => {
		const hasImage = url.trim().length > 0;
		attachmentEmpty.classList.toggle("hidden", hasImage);
		attachmentPreview.classList.toggle("hidden", !hasImage);
		attachmentPreviewImage.src = hasImage ? url : "";
	};

	const getSeriesVolumeKey = () => {
		if (!seriesSelect.value || !volumeSelect.value) return "";
		return `${seriesSelect.value}/${volumeSelect.value}`;
	};

	const syncDependentVisibility = () => {
		const shouldShow = Boolean(seriesSelect.value) && Boolean(volumeSelect.value) && Boolean(chapterSelect.value);
		dependentFields.classList.toggle("hidden", !shouldShow);

		if (!shouldShow) {
			errorTypeInput.value = "";
			errorTypeOptions.forEach((option) => {
				option.classList.remove("bg-[rgba(255,74,74,0.1)]", "text-[#dd7373]");
				option.classList.add("bg-white/10", "text-[#bc9999]");
			});
		}
	};

	const syncSubmitState = () => {
		const requiredReady = Boolean(seriesSelect.value)
			&& Boolean(volumeSelect.value)
			&& Boolean(chapterSelect.value)
			&& Boolean(errorTypeInput.value)
			&& passageInput.value.trim().length > 0;

		submitButton.disabled = !requiredReady;
		submitButton.classList.toggle("bg-[#da8585]/80", requiredReady);
		submitButton.classList.toggle("text-[#ffd0d0]", requiredReady);
		submitButton.classList.toggle("cursor-pointer", requiredReady);
		submitButton.classList.toggle("hover:bg-[#da8585]", requiredReady);
		submitButton.classList.toggle("bg-[#725858]", !requiredReady);
		submitButton.classList.toggle("text-[#d7bbbb]", !requiredReady);
		submitButton.classList.toggle("cursor-not-allowed", !requiredReady);
	};

	const populateChapterOptions = (preferredChapter = "") => {
		chapterSelect.innerHTML = "";
		const placeholder = document.createElement("option");
		placeholder.value = "";
		placeholder.textContent = "Select Chapter";
		chapterSelect.appendChild(placeholder);

		const seriesVolumeKey = getSeriesVolumeKey();
		if (!seriesVolumeKey) {
			chapterSelect.disabled = true;
			chapterSelect.value = "";
			syncCustomSelect("chapter");
			syncDependentVisibility();
			syncSubmitState();
			return;
		}

		const chapters = Array.isArray(chaptersBySeriesVolume[seriesVolumeKey]) ? chaptersBySeriesVolume[seriesVolumeKey] : [];
		for (const chapter of chapters) {
			const option = document.createElement("option");
			option.value = chapter.value;
			option.textContent = chapter.label;
			chapterSelect.appendChild(option);
		}

		chapterSelect.disabled = false;
		if (preferredChapter && chapters.some((chapter) => chapter.value === preferredChapter)) {
			chapterSelect.value = preferredChapter;
		}

		syncCustomSelect("chapter");

		syncDependentVisibility();
		syncSubmitState();
	};

	const populateVolumeOptions = (selectedSeries: string, preferredVolume = "", preferredChapter = "") => {
		volumeSelect.innerHTML = "";
		const placeholder = document.createElement("option");
		placeholder.value = "";
		placeholder.textContent = "Select Volume";
		volumeSelect.appendChild(placeholder);

		if (!selectedSeries) {
			volumeSelect.disabled = true;
			volumeSelect.value = "";
			syncCustomSelect("volume");
			populateChapterOptions();
			return;
		}

		const volumes = Array.isArray(volumeOptionsBySeries[selectedSeries]) ? volumeOptionsBySeries[selectedSeries] : [];
		for (const volume of volumes) {
			const option = document.createElement("option");
			option.value = volume.value;
			option.textContent = volume.label;
			volumeSelect.appendChild(option);
		}

		volumeSelect.disabled = false;
		if (preferredVolume && volumes.some((volume) => volume.value === preferredVolume)) {
			volumeSelect.value = preferredVolume;
		}

		syncCustomSelect("volume");

		populateChapterOptions(preferredChapter);
	};

	const applyQueryDefaults = () => {
		const url = new URL(window.location.href);
		const preferredSeries = url.searchParams.get("series") || url.searchParams.get("s") || "";
		const preferredVolume = url.searchParams.get("volume") || url.searchParams.get("v") || "";
		const preferredChapter = url.searchParams.get("chapter") || url.searchParams.get("c") || "";

		if (preferredSeries) {
			const matchingSeries = Array.from(seriesSelect.options).find((option) => {
				return option.value === preferredSeries;
			});

			if (matchingSeries) {
				seriesSelect.value = matchingSeries.value;
			}
		}

		populateVolumeOptions(seriesSelect.value, preferredVolume, preferredChapter);
	};

	const setErrorType = (value: string) => {
		errorTypeInput.value = value;
		errorTypeOptions.forEach((option) => {
			const isSelected = option.getAttribute("data-error-type-option") === value;
			option.classList.toggle("bg-[rgba(255,74,74,0.1)]", isSelected);
			option.classList.toggle("text-[#dd7373]", isSelected);
			option.classList.toggle("bg-white/10", !isSelected);
			option.classList.toggle("text-[#bc9999]", !isSelected);
		});
		syncSubmitState();
	};

	const updateAttachmentStatus = (text: string, isError = false) => {
		attachmentStatus.textContent = text;
		attachmentStatus.classList.toggle("text-[#d98585]", !isError);
		attachmentStatus.classList.toggle("text-[#ff8b8b]", isError);
	};

	const fileToBase64 = (file: File): Promise<string> => {
		return new Promise((resolve, reject) => {
			const reader = new FileReader();
			reader.onload = () => {
				const result = typeof reader.result === "string" ? reader.result : "";
				const base64 = result.includes(",") ? result.split(",")[1] : result;
				resolve(base64);
			};
			reader.onerror = () => reject(new Error("Failed to read image file."));
			reader.readAsDataURL(file);
		});
	};

	const uploadImageToImgbb = async (file: File) => {
		if (!imgbbApiKey) {
			updateAttachmentStatus("ImgBB is not configured yet. Set PUBLIC_IMGBB_API_KEY to enable uploads.", true);
			return;
		}

		updateAttachmentStatus("Uploading image...");

		try {
			const base64Image = await fileToBase64(file);
			const body = new URLSearchParams();
			body.set("image", base64Image);
			body.set("name", file.name || "error-report");

			const response = await fetch(`https://api.imgbb.com/1/upload?key=${encodeURIComponent(imgbbApiKey)}`, {
				method: "POST",
				body,
			});

			if (!response.ok) {
				throw new Error(`ImgBB upload failed: ${response.status}`);
			}

			const payload = await response.json();
			const imageUrl = payload?.data?.url;
			if (typeof imageUrl !== "string" || imageUrl.length === 0) {
				throw new Error("ImgBB did not return an image URL.");
			}

			attachmentUrlInput.value = imageUrl;
			syncAttachmentPreview(imageUrl);
			updateAttachmentStatus("Image uploaded successfully.");
		} catch (error) {
			attachmentUrlInput.value = "";
			syncAttachmentPreview("");
			updateAttachmentStatus("Image upload failed. Please try again.", true);
			console.error(error);
		}
	};

	const handleImageFile = (file: File) => {
		if (!file || !file.type.startsWith("image/")) {
			updateAttachmentStatus("Only image files are supported.", true);
			return;
		}

		uploadImageToImgbb(file);
	};

	seriesSelect.addEventListener("change", () => {
		syncCustomSelect("series");
		populateVolumeOptions(seriesSelect.value);
	});

	volumeSelect.addEventListener("change", () => {
		syncCustomSelect("volume");
		populateChapterOptions();
	});

	chapterSelect.addEventListener("change", () => {
		syncCustomSelect("chapter");
		syncDependentVisibility();
		syncSubmitState();
	});

	passageInput.addEventListener("input", syncSubmitState);

	errorTypeOptions.forEach((option) => {
		option.addEventListener("click", () => {
			const value = option.getAttribute("data-error-type-option") || "";
			setErrorType(value);
		});
	});

	dropzone.addEventListener("click", () => fileInput.click());
	dropzone.addEventListener("keydown", (event) => {
		if (event.key === "Enter" || event.key === " ") {
			event.preventDefault();
			fileInput.click();
		}
	});

	form.addEventListener("paste", (event) => {
		const items = event.clipboardData?.items;
		if (!items) return;
		for (const item of items) {
			if (item.type.startsWith("image/")) {
				event.preventDefault();
				const file = item.getAsFile();
				if (file) handleImageFile(file);
				return;
			}
		}
	});

	dropzone.addEventListener("dragover", (event) => {
		event.preventDefault();
		dropzone.classList.add("border-white/35");
	});

	attachmentClearButton.addEventListener("click", (event) => {
		event.stopPropagation();
		attachmentUrlInput.value = "";
		fileInput.value = "";
		syncAttachmentPreview("");
		updateAttachmentStatus("Attachment removed.");
	});

	dropzone.addEventListener("dragleave", () => {
		dropzone.classList.remove("border-white/35");
	});

	dropzone.addEventListener("drop", (event) => {
		event.preventDefault();
		dropzone.classList.remove("border-white/35");
		const file = event.dataTransfer?.files?.[0];
		if (file) handleImageFile(file);
	});

	fileInput.addEventListener("change", () => {
		const file = fileInput.files?.[0];
		if (file) handleImageFile(file);
	});

	resetButton.addEventListener("click", () => {
		form.reset();
		syncCustomSelect("series");
		errorTypeInput.value = "";
		attachmentUrlInput.value = "";
		fileInput.value = "";
		syncAttachmentPreview("");
		updateAttachmentStatus("");
		populateVolumeOptions("");
		syncDependentVisibility();
		syncSubmitState();
	});

	form.addEventListener("submit", async (event) => {
		event.preventDefault();
		syncSubmitState();
		if (submitButton.disabled) return;

		if (!publicWorkerUrl) {
			updateAttachmentStatus("Submit endpoint is not configured yet.", true);
			return;
		}

		submitButton.disabled = true;
		submitButton.textContent = "Submitting...";

		const payload = {
			series: seriesSelect.value,
			volume: volumeSelect.value,
			chapter: chapterSelect.value,
			errorType: errorTypeInput.value,
			passage: passageInput.value.trim(),
			contact: (() => {
				const contactField = form.elements.namedItem("contact");
				return contactField instanceof HTMLInputElement ? contactField.value.trim() : "";
			})(),
			attachmentUrl: attachmentUrlInput.value,
		};

		try {
			const response = await fetch(publicWorkerUrl, {
				method: "POST",
				headers: {
					"Content-Type": "application/json"
				},
				body: JSON.stringify(payload),
			});

			if (!response.ok) {
				throw new Error(`Submit failed: ${response.status}`);
			}

			formShell.classList.add("hidden");
			thankYou.classList.remove("hidden");
		} catch (error) {
			console.error(error);
			updateAttachmentStatus("Failed to submit report. Please try again.", true);
			submitButton.disabled = false;
			submitButton.textContent = "Submit";
		}
	});

	applyQueryDefaults();
	syncCustomSelect("series");
	syncCustomSelect("volume");
	syncCustomSelect("chapter");
	syncAttachmentPreview(attachmentUrlInput.value);
	syncDependentVisibility();
	syncSubmitState();
</script>
